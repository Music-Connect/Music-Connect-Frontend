# --- SERVIDOR ---
PORT=3001
NODE_ENV=development

# --- BANCO DE DADOS ---
DB_HOST=localhost
DB_PORT=5433
DB_USER=music_user
DB_PASSWORD=postgres
DB_NAME=music_connect_db

# --- SEGURANÇA (JWT) ---
JWT_SECRET=seu_segredo_super_secreto_aqui_mudar_em_producao
JWT_EXPIRES_IN=7d

# --- PERMISSÕES (CORS) ---
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# --- EMAIL (Gmail SMTP) ---
# Para usar Gmail, você precisa:
# 1. Ativar autenticação de 2 fatores na sua conta Google
# 2. Gerar uma "App Password" em: https://myaccount.google.com/apppasswords
# 3. Usar a senha de aplicativo (não sua senha normal do Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_aplicativo_de_16_digitos
EMAIL_FROM=Music Connect <seu_email@gmail.com>

# --- FRONTEND (Para links de reset de senha) ---
FRONTEND_URL=http://localhost:3000
